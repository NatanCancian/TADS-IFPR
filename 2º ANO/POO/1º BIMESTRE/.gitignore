# Dependencies
*/node_modules

# Build artifacts (JavaScript output and source maps)
# Replace as required with your project's build location (e.g., /dist, /build, /out)
*/build
*/dist
*/*.js
!*.config.js
*/*.js.map
*/*.d.ts

# Optional: TypeScript cache file
.tsbuildinfo

# Environment files
.env
.env.*
!.env.example # Allow committing an example environment file

# Testing and coverage
/coverage
.nyc_output

# Logs and debug files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE specific files (e.g., VS Code)
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db